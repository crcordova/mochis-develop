# ============================================
# mochis-play — .gitignore (consolidado)
# ============================================

# ---- Dependencies ----
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz
.pnpm-store/

# ---- Next.js build outputs ----
/.next/
/out/
/build/
next-env.d.ts
*.tsbuildinfo

# ---- Environment files (NEVER commit secrets) ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
!.env.example

# ---- Vercel ----
.vercel

# ---- Testing & Coverage ----
/coverage
/test-results/
/playwright-report/
/playwright/.cache/

# ---- OS / Editor ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*.pem

# ---- Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ============================================
# Opencode / Agents
# ============================================
# Keep: .opencode/agents/*.md, .opencode/package.json, .opencode/package-lock.json, .opencode/.gitignore
# Ignore: .opencode/node_modules/ (large, regenerated by npm install)
.opencode/node_modules/

# ============================================
# Agent-Orquest (orchestration methodology + history)
# ============================================
# The Agent-Orquest folder contains the multi-agent methodology,
# specs, and reports. We keep the current state, not historical drafts.

# Ignore duplicated nested .opencode inside Agent-Orquest
Agent-Orquest/.opencode/

# ---- Prompts (historical — replaced by handoff design images) ----
Agent-Orquest/docs/orchestration/prompts/

